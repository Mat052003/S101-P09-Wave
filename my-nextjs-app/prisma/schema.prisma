generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  password      String?
  image         String?
  role          Role      @default(USER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  otpCodes      OtpCode[]
  reservations  Reservation[]
  hotels        Hotel[]
  reviews       Review[]
  reviewReports ReviewReport[]
  experiences   Experience[]
  extraServices ExtraService[]
}

enum Role {
  USER
  ADMIN
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model OtpCode {
  id        String   @id @default(cuid())
  userId    String
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Hotel {
  id                String         @id @default(cuid())
  name              String
  description       String
  location          String
  experienceType    ExperienceType @default(RELAX)
  price             Float
  extraBedPrice     Float          @default(50)
  stars             Int            @default(5)
  services          String[]       @default([])
  exclusiveFeatures String[]       @default([])
  images            String[]
  ownerId           String?
  totalRooms        Int            @default(10)
  isActive          Boolean        @default(true)
  latitude          Float?
  longitude         Float?
  address           String?
  googlePlaceId     String?

  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  owner             User?               @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  reservations      Reservation[]
  reviews           Review[]
  blockedDates      BlockedDate[]
  experiences       HotelExperience[]
  extraServices     HotelExtraService[]
}

enum ExperienceType {
  RELAX
  WELLNESS
  GASTRONOMIC
  ADVENTURE
  ROMANTIC
  CULTURAL
}

model Reservation {
  id         String            @id @default(cuid())
  userId     String
  hotelId    String
  checkIn    DateTime
  checkOut   DateTime
  guests     Int               @default(1)
  rooms      Int               @default(1)
  totalPrice Float
  status     ReservationStatus @default(PENDING)

  extras     ReservationExtra[]
  review     Review?

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  hotel Hotel @relation(fields: [hotelId], references: [id], onDelete: Cascade)
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

model ReservationExtra {
  id            String    @id @default(cuid())
  reservationId String
  type          ExtraType
  price         Float
  quantity      Int       @default(1)
  notes         String?

  reservation Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
}

enum ExtraType {
  BREAKFAST
  SPA
  TOUR
  TRANSPORT
}

model BlockedDate {
  id        String   @id @default(cuid())
  hotelId   String
  date      DateTime
  reason    String?
  createdAt DateTime @default(now())

  hotel Hotel @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@unique([hotelId, date])
}

model Review {
  id            String    @id @default(cuid())
  hotelId       String
  userId        String
  reservationId String    @unique
  rating        Int
  cleanliness   Int
  location      Int
  service       Int
  comment       String
  ownerReply    String?
  ownerReplyAt  DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  hotel       Hotel       @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  reservation Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  reports     ReviewReport[]
}

model ReviewReport {
  id        String   @id @default(cuid())
  reviewId  String
  userId    String
  reason    String
  createdAt DateTime @default(now())

  review Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ── EXPERIENCIAS ─────────────────────────────────────────────
model Experience {
  id          String             @id @default(cuid())
  ownerId     String
  name        String
  description String
  price       Float
  duration    String?
  category    ExperienceCategory @default(ACTIVITY)
  images      String[]
  isActive    Boolean            @default(true)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  owner  User              @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  hotels HotelExperience[]
}

enum ExperienceCategory {
  ACTIVITY
  GASTRONOMY
  TOUR
  WELLNESS
  ADVENTURE
}

model HotelExperience {
  hotelId      String
  experienceId String

  hotel      Hotel      @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  experience Experience @relation(fields: [experienceId], references: [id], onDelete: Cascade)

  @@id([hotelId, experienceId])
}

// ── EXTRAS ───────────────────────────────────────────────────
model ExtraService {
  id          String    @id @default(cuid())
  ownerId     String
  name        String
  description String?
  price       Float
  image       String?
  type        ExtraType
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  owner  User                @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  hotels HotelExtraService[]
}

model HotelExtraService {
  hotelId        String
  extraServiceId String

  hotel        Hotel        @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  extraService ExtraService @relation(fields: [extraServiceId], references: [id], onDelete: Cascade)

  @@id([hotelId, extraServiceId])
}

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Hotel {
  id          String   @id @default(cuid())
  name        String
  description String
  location    String
  price       Float
  stars       Int      @default(5)
  images      String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
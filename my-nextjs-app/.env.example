# ─── Base de datos (Supabase) ─────────────────────────────────────────────────
# Obtener desde: Supabase → Project Settings → Database → Connection Pooler (Transaction mode)
# IMPORTANTE: Añadir ?pgbouncer=true&connection_limit=1 al final para Vercel Serverless
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# ─── Auth.js / NextAuth ───────────────────────────────────────────────────────
# Generar con: openssl rand -base64 32  (o cualquier string largo y aleatorio)
NEXTAUTH_SECRET="GENERAR-UN-SECRET-LARGO-Y-ALEATORIO"
# En Vercel: poner la URL de tu proyecto (ej: https://wave.vercel.app)
NEXTAUTH_URL="https://tu-proyecto.vercel.app"

# ─── Google OAuth (Login con Google) ─────────────────────────────────────────
# Obtener desde: Google Cloud Console → APIs & Services → Credentials
GOOGLE_CLIENT_ID="tu-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="GOCSPX-tu-client-secret"

# ─── Google Maps API Key ──────────────────────────────────────────────────────
# Obtener desde: Google Cloud Console → APIs & Services → Credentials
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY="tu-api-key-google-maps"

# ─── Email / SMTP (Opcional - para OTP en registro) ──────────────────────────
# Si no se configura, el sistema usa Ethereal (correos de prueba) en development.
# Para producción, se recomienda configurar con Gmail o un servicio SMTP real.
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="tu-correo@gmail.com"
SMTP_PASS="tu-app-password-de-gmail"
